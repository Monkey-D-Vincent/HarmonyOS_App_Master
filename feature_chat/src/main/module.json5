{
  "module": {
    "name": "feature_chat",
    "type": "feature",
    "description": "$string:module_desc",
    "mainElement": "FeatureChatAbility",
    "deviceTypes": [
      "phone"
    ],
    "deliveryWithInstall": true,
    "installationFree": false,
    "pages": "$profile:main_pages",
    "abilities": [
      {
        "name": "FeatureChatAbility",
        "srcEntry": "./ets/featurechatability/FeatureChatAbility.ets",
        "description": "$string:FeatureChatAbility_desc",
        "icon": "$media:layered_image",
        "label": "$string:FeatureChatAbility_label",
        "startWindowIcon": "$media:startIcon",
        "startWindowBackground": "$color:start_window_background",
        "exported": true
      }
    ]
  }
}